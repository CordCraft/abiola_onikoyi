// Prisma schema for the private projects area.
// Local development uses SQLite; production uses Postgres (Neon).
// The models below are intentionally provider-agnostic so the same schema
// works in both — we use `prisma db push` rather than migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  summary   String
  // One of: "idea" | "building" | "launched" | "paused" (validated in app code)
  status    String    @default("building")
  link      String?
  startedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  updates   Update[]
}

model Update {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  title     String
  body      String // markdown
  createdAt DateTime @default(now())
}

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  body        String // markdown
  // One of the "What I bring" themes, e.g. "Reservoir & Production"
  category    String
  // "news" | "insight"
  kind        String    @default("insight")
  // SEO
  metaDescription String?
  keywords        String? // comma-separated
  // Article image (sourced from Openverse)
  imageUrl       String?
  imageAlt       String?
  imageCredit    String?
  imageCreditUrl String?
  sourceUrl   String?
  sourceName  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
}
