// Prisma schema for the private projects area.
// Local development uses SQLite; production uses Postgres (Neon).
// The models below are intentionally provider-agnostic so the same schema
// works in both — we use `prisma db push` rather than migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  summary   String
  // One of: "idea" | "building" | "launched" | "paused" (validated in app code)
  status    String    @default("building")
  link      String?
  startedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  updates   Update[]
}

model Update {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  title     String
  body      String // markdown
  createdAt DateTime @default(now())
}

model Post {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String
  body            String // markdown
  // One of the "What I bring" themes, e.g. "Reservoir & Production"
  category        String
  // "news" | "insight"
  kind            String    @default("insight")
  // SEO
  metaDescription String?
  keywords        String? // comma-separated
  // Article image (sourced from Openverse)
  imageUrl        String?
  imageAlt        String?
  imageCredit     String?
  imageCreditUrl  String?
  sourceUrl       String?
  sourceName      String?
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([published, publishedAt])
}

// ---------------------------------------------------------------------------
// Jarvis — personal second brain (private /jarvis area)
// ---------------------------------------------------------------------------

model JarvisVenture {
  id          String          @id @default(cuid())
  name        String
  description String?
  status      String          @default("active") // active | paused | archived
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  projects    JarvisProject[]
  notes       JarvisNote[]
}

model JarvisProject {
  id             String           @id @default(cuid())
  name           String
  venture        JarvisVenture?   @relation(fields: [ventureId], references: [id], onDelete: SetNull)
  ventureId      String?
  status         String           @default("active") // idea | active | stalled | paused | done
  priority       String           @default("medium") // low | medium | high
  summary        String?
  lastActivityAt DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tasks          JarvisTask[]
  notes          JarvisNote[]
  decisions      JarvisDecision[]
  documents      JarvisDocument[]

  @@index([status, lastActivityAt])
}

model JarvisTask {
  id          String         @id @default(cuid())
  project     JarvisProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String?
  title       String
  status      String         @default("todo") // todo | doing | done
  priority    String         @default("medium")
  dueDate     DateTime?
  completedAt DateTime?
  // "daily" | "weekly" | "monthly": completing the task spawns the next occurrence
  recurrence  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, dueDate])
}

model JarvisNote {
  id        String         @id @default(cuid())
  project   JarvisProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?
  venture   JarvisVenture? @relation(fields: [ventureId], references: [id], onDelete: Cascade)
  ventureId String?
  body      String
  tags      String?
  // "capture" = quick-capture inbox item awaiting filing; null = normal note
  source    String?
  createdAt DateTime       @default(now())

  @@index([createdAt])
}

model JarvisDecision {
  id        String         @id @default(cuid())
  project   JarvisProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?
  title     String
  rationale String
  createdAt DateTime       @default(now())
}

model JarvisGoal {
  id          String            @id @default(cuid())
  title       String
  description String?
  horizon     String? // freeform, e.g. "wealth", "autism impact"
  status      String            @default("active")
  targetDate  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  milestones  JarvisMilestone[]
}

model JarvisMilestone {
  id        String     @id @default(cuid())
  goal      JarvisGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  goalId    String
  title     String
  done      Boolean    @default(false)
  dueDate   DateTime?
  createdAt DateTime   @default(now())
}

model JarvisThread {
  id        String           @id @default(cuid())
  title     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  JarvisMessage[]
  proposals JarvisProposal[]
}

model JarvisMessage {
  id        String       @id @default(cuid())
  thread    JarvisThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId  String
  role      String // user | assistant
  content   String
  // SavedRecord[] receipts from the turn that produced this assistant message
  receipts  Json?
  createdAt DateTime     @default(now())

  @@index([threadId, createdAt])
}

// Single-user key-value settings (calendar ICS url, briefing preferences, ...).
model JarvisSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// A document uploaded through chat (or elsewhere): the extracted text content
// is stored durably so knowledge from files is never lost, and can be searched
// and re-read by Jarvis in any future conversation.
model JarvisDocument {
  id        String         @id @default(cuid())
  name      String
  mimeType  String?
  content   String // extracted text
  summary   String? // Jarvis-written 1-3 sentence summary
  project   JarvisProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId String?
  createdAt DateTime       @default(now())

  @@index([projectId, createdAt])
}

// Checkpoint of an in-flight chat turn. Long research turns outlive a single
// Netlify invocation; the route checkpoints here and the client immediately
// resumes in a fresh invocation. Rows are consumed on resume.
model JarvisTurnState {
  id        String   @id @default(cuid())
  threadId  String
  state     Json
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Web Push subscription for one browser/device (proactive briefings + nudges).
model JarvisPushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
}

model JarvisProposal {
  id        String        @id @default(cuid())
  thread    JarvisThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId  String?
  kind      String // create_project | update_project | create_task | log_note | log_decision | set_goal
  summary   String // human-readable one-liner for the confirm card
  payload   Json
  status    String        @default("pending") // pending | applied | discarded
  createdAt DateTime      @default(now())
  appliedAt DateTime?

  @@index([status, createdAt])
}

// ---------------------------------------------------------------------------
// Mentorship programme (public /mentorship + mentee portal + admin area)
// Tables are created in production by ensureMentorshipTables() in
// src/lib/mentorship/setup.ts (idempotent raw DDL), since deploys never run
// `prisma db push` automatically. Keep that DDL in sync with these models.
// ---------------------------------------------------------------------------

model MentorshipMentee {
  id          String              @id @default(cuid())
  name        String
  email       String              @unique // stored lowercase
  accessCode  String              @unique // invite code the mentor shares privately
  headline    String? // e.g. "500-level Chemical Engineering, UNILAG"
  focusArea   String? // e.g. "Process safety and tech"
  cohort      String              @default("2026-C1")
  active      Boolean             @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  goals       MentorshipGoal[]
  tasks       MentorshipTask[]
  checkins    MentorshipCheckin[]
  messages    MentorshipMessage[]
  sessions    MentorshipSession[]
}

model MentorshipGoal {
  id          String           @id @default(cuid())
  mentee      MentorshipMentee @relation(fields: [menteeId], references: [id], onDelete: Cascade)
  menteeId    String
  title       String
  detail      String?
  // "active" | "completed" | "dropped" (validated in app code)
  status      String           @default("active")
  // Programme month the goal targets: 1, 2 or 3
  targetMonth Int?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tasks       MentorshipTask[]

  @@index([menteeId, status])
}

model MentorshipTask {
  id          String           @id @default(cuid())
  mentee      MentorshipMentee @relation(fields: [menteeId], references: [id], onDelete: Cascade)
  menteeId    String
  goal        MentorshipGoal?  @relation(fields: [goalId], references: [id], onDelete: SetNull)
  goalId      String?
  title       String
  notes       String?
  // "mentor" | "mentee": who created the task
  createdBy   String           @default("mentor")
  dueDate     DateTime?
  // "todo" | "done"
  status      String           @default("todo")
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([menteeId, status])
}

model MentorshipCheckin {
  id          String           @id @default(cuid())
  mentee      MentorshipMentee @relation(fields: [menteeId], references: [id], onDelete: Cascade)
  menteeId    String
  // Programme week number (1..13)
  week        Int
  wins        String
  blockers    String?
  nextFocus   String?
  // Self-rated confidence for the week, 1..5
  confidence  Int?
  mentorReply String?
  repliedAt   DateTime?
  createdAt   DateTime         @default(now())

  @@index([menteeId, week])
  @@index([createdAt])
}

model MentorshipMessage {
  id        String           @id @default(cuid())
  mentee    MentorshipMentee @relation(fields: [menteeId], references: [id], onDelete: Cascade)
  menteeId  String
  // "mentor" | "mentee"
  sender    String
  body      String
  createdAt DateTime         @default(now())
  readAt    DateTime?

  @@index([menteeId, createdAt])
}

model MentorshipSession {
  id          String            @id @default(cuid())
  title       String
  // "group" | "one_on_one"
  kind        String            @default("group")
  // Null for group sessions (whole cohort)
  mentee      MentorshipMentee? @relation(fields: [menteeId], references: [id], onDelete: Cascade)
  menteeId    String?
  scheduledAt DateTime
  link        String? // Google Meet or similar
  agenda      String?
  notes       String? // mentor's post-session notes, visible to attendees
  // "upcoming" | "completed" | "cancelled"
  status      String            @default("upcoming")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([scheduledAt])
}

model MentorshipResource {
  id        String   @id @default(cuid())
  title     String
  url       String?
  note      String?
  // "reading" | "video" | "course" | "tool" | "other"
  category  String   @default("reading")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MentorshipAnnouncement {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
}
